[
  {"id": 1, "text": "সব কাজ নিয়তের উপর নির্ভরশীল।", "reference": "সহীহ বুখারী"},
  {"id": 2, "text": "তোমাদের মধ্যে উত্তম সেই ব্যক্তি, যে কুরআন শেখে ও শেখায়।", "reference": "সহীহ বুখারী"},
  {"id": 3, "text": "মুসলিম সেই ব্যক্তি, যার হাত ও জিহ্বা থেকে অন্যরা নিরাপদ থাকে।", "reference": "সহীহ বুখারী"},
  {"id": 4, "text": "পবিত্রতা ঈমানের অর্ধেক।", "reference": "সহীহ মুসলিম"},
  {"id": 5, "text": "সত্য নেকির দিকে নিয়ে যায়।", "reference": "সহীহ বুখারী"},
  {"id": 6, "text": "মিথ্যা পাপের দিকে নিয়ে যায়।", "reference": "সহীহ মুসলিম"},
  {"id": 7, "text": "ভালো কথা বলো অথবা চুপ থাকো।", "reference": "সহীহ বুখারী"},
  {"id": 8, "text": "দান সম্পদ কমায় না।", "reference": "সহীহ মুসলিম"},
  {"id": 9, "text": "মায়ের পায়ের নিচে সন্তানের জান্নাত।", "reference": "নাসাঈ"},
  {"id": 10, "text": "হাসিমুখে কথা বলাও সদকা।", "reference": "তিরমিজি"},
  {"id": 11, "text": "মানুষের মধ্যে উত্তম সেই, যে মানুষের উপকার করে।", "reference": "তাবারানী"},
  {"id": 12, "text": "ধৈর্য আলোস্বরূপ।", "reference": "সহীহ মুসলিম"},
  {"id": 13, "text": "শক্তিশালী সে, যে রাগের সময় নিজেকে নিয়ন্ত্রণ করে।", "reference": "সহীহ বুখারী"},
  {"id": 14, "text": "সহজ করো, কঠিন করো না।", "reference": "সহীহ বুখারী"},
  {"id": 15, "text": "আল্লাহর উপর ভরসা করো।", "reference": "তিরমিজি"},
  {"id": 16, "text": "আল্লাহ সুন্দর, তিনি সৌন্দর্য ভালোবাসেন।", "reference": "সহীহ মুসলিম"},
  {"id": 17, "text": "অতিথিকে সম্মান করো।", "reference": "সহীহ বুখারী"},
  {"id": 18, "text": "ক্ষমা করলে মর্যাদা বৃদ্ধি পায়।", "reference": "সহীহ মুসলিম"},
  {"id": 19, "text": "যে দয়া করে না, তার প্রতি দয়া করা হয় না।", "reference": "সহীহ বুখারী"},
  {"id": 20, "text": "অহংকারী জান্নাতে প্রবেশ করবে না।", "reference": "সহীহ মুসলিম"},
  {"id": 21, "text": "শ্রমিকের ঘাম শুকানোর আগেই তার মজুরি দাও।", "reference": "ইবনে মাজাহ"},
  {"id": 22, "text": "প্রতিটি ভালো কাজ সদকা।", "reference": "সহীহ বুখারী"},
  {"id": 23, "text": "রোজা ঢালস্বরূপ।", "reference": "সহীহ বুখারী"},
  {"id": 24, "text": "আমানতদার ব্যক্তির ঈমান পূর্ণ।", "reference": "মুসনাদ আহমাদ"},
  {"id": 25, "text": "পানি অপচয় করো না।", "reference": "ইবনে মাজাহ"},
  {"id": 26, "text": "যে প্রতারণা করে, সে আমাদের দলভুক্ত নয়।", "reference": "সহীহ মুসলিম"},
  {"id": 27, "text": "নম্রতা মর্যাদা বৃদ্ধি করে।", "reference": "সহীহ মুসলিম"},
  {"id": 28, "text": "কৃপণতা থেকে বাঁচো।", "reference": "সহীহ মুসলিম"},
  {"id": 29, "text": "নিজের জন্য যা ভালোবাসো, ভাইয়ের জন্যও তা ভালোবাসো।", "reference": "সহীহ বুখারী"},
  {"id": 30, "text": "দুনিয়া মুমিনের কারাগার।", "reference": "সহীহ মুসলিম"},
  {"id": 31, "text": "অত্যাচারীর সামনে সত্য কথা বলা উত্তম জিহাদ।", "reference": "তিরমিজি"},
  {"id": 32, "text": "আল্লাহ তোমাদের অন্তর ও আমল দেখেন।", "reference": "সহীহ মুসলিম"},
  {"id": 33, "text": "যে ক্ষমা করে, আল্লাহ তাকে সম্মানিত করেন।", "reference": "সহীহ মুসলিম"},
  {"id": 34, "text": "সুন্দর চরিত্র সবচেয়ে ভারী আমল।", "reference": "তিরমিজি"},
  {"id": 35, "text": "মানুষের প্রতি কৃতজ্ঞ নয়, সে আল্লাহর প্রতিও কৃতজ্ঞ নয়।", "reference": "তিরমিজি"},
  {"id": 36, "text": "নরম আচরণ সৌন্দর্য বৃদ্ধি করে।", "reference": "সহীহ মুসলিম"},
  {"id": 37, "text": "কবর আখিরাতের প্রথম ধাপ।", "reference": "তিরমিজি"},
  {"id": 38, "text": "আল্লাহর জিকিরে অন্তর প্রশান্ত হয়।", "reference": "বায়হাকী"},
  {"id": 39, "text": "প্রতিবেশীকে কষ্ট দিও না।", "reference": "সহীহ বুখারী"},
  {"id": 40, "text": "দুনিয়ায় পথিকের মতো থাকো।", "reference": "সহীহ বুখারী"},
  {"id": 41, "text": "তওবাকারী গুনাহহীনের মতো।", "reference": "ইবনে মাজাহ"},
  {"id": 42, "text": "আল্লাহ ক্ষমা করতে ভালোবাসেন।", "reference": "তিরমিজি"},
  {"id": 43, "text": "অল্প হলেও নিয়মিত আমল উত্তম।", "reference": "সহীহ বুখারী"},
  {"id": 44, "text": "মুসলিম মুসলিমের ভাই।", "reference": "সহীহ মুসলিম"},
  {"id": 45, "text": "সুদ ধ্বংস ডেকে আনে।", "reference": "ইবনে মাজাহ"},
  {"id": 46, "text": "রাগ শয়তানের পক্ষ থেকে আসে।", "reference": "আবু দাউদ"},
  {"id": 47, "text": "প্রত্যেক আমলের হিসাব হবে।", "reference": "তিরমিজি"},
  {"id": 48, "text": "দুনিয়া অস্থায়ী ভোগ মাত্র।", "reference": "সহীহ মুসলিম"},
  {"id": 49, "text": "যে আল্লাহর জন্য বিনয়ী হয়, আল্লাহ তাকে উন্নত করেন।", "reference": "সহীহ মুসলিম"},
  {"id": 50, "text": "সর্বোত্তম মানুষ সেই, যার জীবন দীর্ঘ এবং আমল উত্তম।", "reference": "তিরমিজি"}
]
